// dbdiagram.io

Table Category{
  id int [primary key] 
  name nvarchar
  deletedAt datetime
  createdAt datetime
  editedAt datetime
}

Table Image{
  id int [primary key]
  productId int
  path varchar
  alt nvarchar
}

Table Product{
  id int [primary key]
  name nvarchar
  price int
  picture varchar
  weight int
  description text
  discount int
  totalPrice int
  categoryId int
  inventoryQuantity int
  soldQuantity int
  createdAt datetime
  deletedAt datetime
  editedAt datetime
  isdeleted bool
}

Table Role{
  id int [primary key]
  name nvarchar
  createdAt datetime
  deletedAt datetime
  editedAt datetime  
}

Table Account{
  id int [primary key]
  username nvarchar
  phone varchar
  email varchar
  password varchar
  avatar varchar
  roleId int
  createdAt datetime
  deletedAt datetime
  editedAt datetime
}

Table Review{
  id int [primary key]
  content text
  productId int
  accountId int
  createdAt datetime
  editedAt datetime
  deletedAt datetime
}
Table Sender{
  id int [primary key]
  fullname nvarchar
  phone varchar
  province nvarchar
  district nvarchar
  ward nvarchar
  fullAddress text
  isSupplier bool
  createdAt datetime
  deletedAt datetime
  editedAt datetime 
}

Table Receiver{
  id int [primary key]
  fullname nvarchar
  phone varchar
  province nvarchar
  district nvarchar
  ward nvarchar
  fullAddress text
  isSupplier bool
  createdAt datetime
  deletedAt datetime
  editedAt datetime 
}

Table Promotion{
  id int [primary key]
  code varchar
  discount int
  name nvarchar
  isActive bool
  createdAt datetime
  deletedAt datetime
  editedAt datetime 
}

Table Status{
  id int [primary key]
  name nvarchar
}

Table Order{
  id int [primary key]
  senderId int
  promotionId int
  receiverId int
  price int
  totalPrice int
  totalWeight int
  note text
  payment_method nvarchar
  statusId int
  createdAt datetime
  deletedAt datetime
  editedAt datetime
}

Table OrderDetail{
  id int [primary key]
  productId int
  orderId int
  quantity int
  totalWeight int
  totalPrice int
}

Table Bill{
  id int [primary key]
  orderId int
  method nvarchar
  status nvarchar
  bank_code varchar
  amount int
  transaction_no nvarchar
  response_code nvarchar
  paid_at datetime
  createdAt datetime
}

Table Cart{
  productId int
}


Ref: "Sender"."id" < "Order"."senderId"

Ref: "Promotion"."id" < "Order"."promotionId"

Ref: "Receiver"."id" < "Order"."receiverId"

Ref: "Status"."id" < "Order"."statusId"

Ref: "Order"."id" < "OrderDetail"."orderId"

Ref: "Product"."id" < "OrderDetail"."productId"

Ref: "Product"."id" < "Image"."productId"

Ref: "Category"."id" < "Product"."categoryId"

Ref: "Order"."id" < "Bill"."orderId"


Ref: "Role"."id" < "Account"."roleId"


Ref: "Account"."id" < "Review"."accountId"

Ref: "Product"."id" < "Review"."productId"